# Runtime environment values injected by UserData when use_runtime_bundle is enabled.
N8N_PORT=5678
OLLAMA_PORT=11434
QDRANT_PORT=6333
CRAWL4AI_PORT=11235
POSTGRES_PASSWORD=changeme
# N8N_ENCRYPTION_KEY is auto-generated during deployment (32 random bytes = 64 hex chars)
# This key encrypts credentials stored in n8n workflows
# If you need to set it manually, uncomment and set a secure random value:
# N8N_ENCRYPTION_KEY=your-64-character-hex-string-here
# CRAWL4AI_API_TOKEN is auto-generated during deployment. Crawl4AI >= 0.9 locks
# itself to an in-container loopback session without one (host requests are reset).
# CRAWL4AI_API_TOKEN=your-32-character-hex-string-here
N8N_METRICS=false
DOCKER_RUNTIME=runc
NVIDIA_VISIBLE_DEVICES=
N8N_HOST=0.0.0.0
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_SECURE_COOKIE=false
N8N_PROXY_HOPS=1
