# ===================================
# n8n Credential Preloading
# ===================================
# Preloads n8n with credentials for stack services (PostgreSQL, Ollama)
# Uses n8n CLI import (writes directly to database, works before owner account setup)

N8N_CREDENTIALS_GUARD="/var/lib/geusemaker/n8n-credentials-configured"
if [ -f "$N8N_CREDENTIALS_GUARD" ]; then
    echo "n8n credentials already configured, skipping"
else
    echo "Configuring n8n credentials for stack services..."

    wait_for_n8n_container() {
        local max_attempts=30
        local attempt=1
        local delay=2

        echo "Waiting for n8n container to be running..."
        while [ $attempt -le $max_attempts ]; do
            local state
            state=$(docker inspect -f '{% raw %}{{.State.Status}}{% endraw %}' n8n 2>/dev/null || echo "unknown")
            if [ "$state" = "running" ]; then
                echo "n8n container is running"
                return 0
            fi
            if [ $attempt -lt $max_attempts ]; then
                echo "  n8n container state: $state (attempt $attempt/$max_attempts)"
                sleep $delay
            fi
            attempt=$((attempt + 1))
        done

        echo "WARNING: n8n container not running after $max_attempts attempts, skipping credential preloading"
        return 1
    }

    import_credentials() {
        local cred_file="/tmp/n8n-import-credentials.json"

        echo "Writing credential definitions..."
        cat > "$cred_file" <<CRED_EOF
[
  {
    "name": "PostgreSQL Local",
    "type": "postgres",
    "data": {
      "host": "postgres",
      "port": 5432,
      "database": "geusemaker",
      "user": "geusemaker",
      "password": "{{ postgres_password }}",
      "ssl": "disable"
    }
  },
  {
    "name": "Ollama Local",
    "type": "ollamaApi",
    "data": {
      "baseUrl": "http://ollama:{{ ollama_port }}"
    }
  }
]
CRED_EOF

        echo "Copying credentials into n8n container..."
        if ! docker cp "$cred_file" n8n:/tmp/n8n-import-credentials.json; then
            echo "  Failed to copy credential file into n8n container"
            rm -f "$cred_file"
            return 1
        fi

        echo "Importing credentials via n8n CLI..."
        local output
        if output=$(docker exec n8n n8n import:credentials --input=/tmp/n8n-import-credentials.json 2>&1); then
            echo "  Credentials imported successfully"
            [ -n "$output" ] && echo "  $output"
        else
            echo "  WARNING: Credential import failed"
            [ -n "$output" ] && echo "  $output"
            echo ""
            echo "  Manual credential setup:"
            echo "    1. Log into n8n UI: http://<public-ip>:{{ n8n_port }}"
            echo "    2. Go to Credentials -> Add Credential"
            echo "    3. PostgreSQL: host=postgres, port=5432, database=geusemaker, user=geusemaker"
            echo "       Password: check runtime.env next to docker-compose.yml on the instance (/root/runtime.env or /opt/geusemaker/runtime/runtime.env)"
            echo "    4. Ollama: base URL = http://ollama:{{ ollama_port }}"
            rm -f "$cred_file"
            docker exec n8n rm -f /tmp/n8n-import-credentials.json 2>/dev/null || true
            return 1
        fi

        rm -f "$cred_file"
        docker exec n8n rm -f /tmp/n8n-import-credentials.json 2>/dev/null || true
        return 0
    }

    if wait_for_n8n_container; then
        if import_credentials; then
            echo "n8n credential preloading completed successfully"
        else
            echo "WARNING: n8n credential preloading failed, credentials must be created manually"
        fi
    else
        echo "WARNING: n8n container not ready, skipping credential preloading"
        echo "  Credentials can be created manually after n8n is accessible"
    fi

    touch "$N8N_CREDENTIALS_GUARD"
fi
