# ===================================
# NGINX Installation and Startup
# ===================================
# Runs AFTER Docker services are started to ensure containers
# are listening on localhost ports before NGINX starts proxying traffic.
# - Tier 1 (dev): HTTPS on :443 with self-signed cert + HTTP :80 redirect
# - Tier 2/3: HTTP on :80 reverse proxy (ALB terminates TLS)

NGINX_GUARD="/var/lib/geusemaker/nginx-configured"
if [ -f "$NGINX_GUARD" ]; then
    echo "NGINX already configured, skipping"
else
    # NGINX is pre-installed in the core dependency batch on Debian/Ubuntu;
    # install here only when missing (Amazon Linux, or unexpected state).
    if ! command -v nginx >/dev/null 2>&1; then
        echo "Installing NGINX web server..."
        if [ "$OS_FAMILY" = "debian" ]; then
            pkg_install nginx
        else
            yum install -y nginx
        fi
    fi

    if ! command -v nginx >/dev/null 2>&1; then
        echo "ERROR: NGINX installation failed"
        exit 1
    fi

    # Remove default NGINX site that may conflict with our config
    rm -f /etc/nginx/sites-enabled/default 2>/dev/null || true

    echo "Validating NGINX configuration..."
    if ! nginx -t 2>&1; then
        echo "ERROR: NGINX configuration validation failed"
        echo "Check /etc/nginx/conf.d/default.conf for syntax errors"
        exit 1
    fi

    echo "Starting NGINX service..."
    if command -v systemctl >/dev/null 2>&1; then
        systemctl enable nginx
        # restart (not start): the package may have auto-started NGINX with its
        # stock default site before our config/default-site removal; a plain
        # start would be a no-op and keep serving the stale configuration.
        systemctl restart nginx

        if ! systemctl is-active --quiet nginx; then
            echo "ERROR: NGINX failed to start"
            systemctl status nginx || true
            exit 1
        fi
    else
        service nginx restart || service nginx start
        chkconfig nginx on 2>/dev/null || true
    fi

    # Package installs are done: let background security updates resume
    # (timers and services stopped at the top of base.sh to keep the dpkg lock free).
    if [ "$OS_FAMILY" = "debian" ]; then
        systemctl start apt-daily.timer apt-daily-upgrade.timer 2>/dev/null || true
        systemctl start unattended-upgrades 2>/dev/null || true
    fi

{% if enable_https and tier == "dev" %}
    echo "NGINX running with self-signed HTTPS on port 443"
{% else %}
    echo "NGINX running as HTTP reverse proxy on port 80 (ALB terminates TLS)"
{% endif %}

    touch "$NGINX_GUARD"
fi
